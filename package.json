{
  "name": "sitephoto",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "test:coverage": "jest --coverage --forceExit",
    "duplication": "jscpd src/ --ignore 'src/__tests__/**'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 75,
        "functions": 65,
        "lines": 90
      }
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/lib-storage": "^3.1052.0",
    "@tmcw/togeojson": "^7.1.2",
    "@xmldom/xmldom": "^0.9.10",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.0",
    "connect-pg-simple": "^10.0.0",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.10.0",
    "sharp": "^0.32.6",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jscpd": "^4.0.9",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
