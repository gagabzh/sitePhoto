# Local dev overrides — copy to .env.local (git-ignored)
# The docker-compose.yml already has safe defaults for most V4 vars.
# Only override here what differs from those defaults.

# Caddy domain (must be set; use localhost for local dev)
DOMAIN=localhost

# Database
DB_PASSWORD=changeme

# Session
SESSION_SECRET=dev-session-secret

# Seed admin account
SEED_NAME=Admin
SEED_EMAIL=admin@example.com
SEED_PASS=changeme

# Shared secret between app and worker (any non-empty string works in dev)
WORKER_API_SECRET=dev-worker-secret

# Redis password (must match the redis service command in docker-compose.yml)
REDIS_PASSWORD=devpassword

# S3 bucket name — MinIO creates it automatically via minio-init
S3_BUCKET=photo-storage

# Ollama — runs on the host machine outside Docker
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull a vision model: ollama pull llava
OLLAMA_HOST=host-gateway
OLLAMA_PORT=11434
OLLAMA_MODEL=llava
