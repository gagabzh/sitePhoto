# Production: your real domain (e.g. photos.example.com)
# Local dev:  localhost  (Caddy serves HTTP, no certificate needed)
DOMAIN=localhost

DB_PASSWORD=change-me-strong-password
# postgresql://sitephoto:<DB_PASSWORD>@db:5432/sitephoto  — replace <DB_PASSWORD> with the value above
DATABASE_URL=postgresql://sitephoto:change-me-strong-password@db:5432/sitephoto
SESSION_SECRET=change-me-random-secret

SEED_NAME=Admin
SEED_EMAIL=admin@example.com
SEED_PASS=change-me-admin-password

# AI features (optional) — Ollama runs on the host, outside Docker.
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull a vision model: ollama pull llava   (or: ollama pull moondream)
# Leave these as-is if Ollama is on the same machine; the app degrades
# gracefully when Ollama is unreachable.
OLLAMA_HOST=host-gateway
OLLAMA_PORT=11434
OLLAMA_MODEL=llava
# or: moondream (lighter, CPU-friendly)

# ── V4 — Redis (Instance-1 only) ─────────────────────────────────────────────
# REDIS_BIND_IP: vRack private IP of Instance-1 (from: terraform output instance1_private_ip)
# Redis will bind to loopback + this IP — never exposed on the public interface.
REDIS_BIND_IP=10.0.0.x
REDIS_HOST=10.0.0.x  # used by Instance-2 worker; app container uses Docker service name (overridden in docker-compose.prod.yml)
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-password

# ── V4 — Worker shared secret ─────────────────────────────────────────────────
# Same value must be set on Instance-2 in .env.worker.
# Generate with: openssl rand -hex 32
WORKER_API_SECRET=change-me-64-char-secret
INTERNAL_API_PORT=3001

# ── V4 — OVH Object Storage (S3-compatible) ───────────────────────────────────
# All values come from: terraform output (run from infra/ directory)
#   S3_ENDPOINT  → terraform output s3_endpoint
#   S3_REGION    → terraform output s3_region
#   S3_BUCKET    → terraform output s3_bucket
#   S3_ACCESS_KEY → terraform output s3_access_key
#   S3_SECRET_KEY → terraform output -raw s3_secret_key
S3_ENDPOINT=https://s3.gra.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=photo-storage
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me

# ── V4 — Instance-2 lifecycle (Phase 11) ─────────────────────────────────────
# Enables auto-unshelve on upload and auto-shelve after idle.
# OVH credentials: create an API key at https://api.ovh.com/createToken/
#   Required rights: GET/POST /cloud/project/*/instance/*
# INSTANCE2_ID: terraform output instance2_id
# OVH_PROJECT_ID: terraform output project_id  (or from OVH control panel)
OVH_APP_KEY=change-me
OVH_APP_SECRET=change-me
OVH_CONSUMER_KEY=change-me
OVH_PROJECT_ID=change-me
INSTANCE2_ID=change-me
INSTANCE2_IDLE_MINUTES=10
