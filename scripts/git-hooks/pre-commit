#!/bin/bash
# Pre-commit hook to prevent commits to main branch

protected_branch="main"
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ "$current_branch" = "$protected_branch" ]; then
  echo "ERROR: Attempting to commit directly to '$protected_branch' branch!"
  echo ""
  echo "NEVER commit directly to main. Always:"
  echo "  1. git checkout -b feat/<name>"
  echo "  2. Make your changes"
  echo "  3. git commit"
  echo "  4. git push origin feat/<name>"
  echo "  5. Create PR from feat/<name> to main"
  echo ""
  echo "Aborting commit."
  exit 1
fi

exit 0
