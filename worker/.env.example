# Redis — point to Instance-1's vRack private IP in production
REDIS_HOST=10.0.0.x
REDIS_PORT=6379
REDIS_PASSWORD=

# Instance-1 internal API — vRack private IP in production
INSTANCE1_API_URL=http://10.0.0.x:3001
WORKER_API_SECRET=

# OVH Object Storage — same credentials as Instance-1
S3_ENDPOINT=https://s3.gra.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=photo-storage
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Ollama — runs locally on Instance-2
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=llava

# Optional: override the identification prompt sent to Ollama
# IDENTIFICATION_PROMPT=List the people visible in this photo. Return JSON: [{"name": "...", "confidence": 0.9}]
